# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]

# Database (Supabase Postgres connection string, asyncpg driver)
# Supabase: Project Settings -> Database -> Connection string -> URI
# (use the "Transaction" pooler on port 6543 for serverless/Railway deploys)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/operator_ai

# IANA timezone the business operates in, e.g. "America/New_York", "Europe/London".
# Used to resolve relative dates/times ("Friday at 2 PM") to the correct local time.
BUSINESS_TIMEZONE=Asia/Kolkata

# Planner LLM -- Groq (OpenAI-compatible API)
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
PLANNER_MODEL=llama-3.3-70b-versatile

# WhatsApp Business Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=change-me
WHATSAPP_PHONE_NUMBER_ID=change-me
WHATSAPP_API_VERSION=v21.0

# Supabase Storage -- stores generated invoice PDFs.
# Project Settings -> API -> Project URL / service_role key.
# Create a bucket (default name "invoices") and mark it public, or adjust
# SupabaseStorageService to use signed URLs if it should stay private.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me
SUPABASE_STORAGE_BUCKET=invoices
INVOICE_CURRENCY_SYMBOL=₹

# Email -- "resend" or "gmail"
EMAIL_PROVIDER=resend

# Resend -- transactional email. Can't send from a gmail.com address
# (requires DNS-verified domain ownership); use EMAIL_PROVIDER=gmail for that.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# Gmail SMTP -- used when EMAIL_PROVIDER=gmail. Sends from a real Gmail
# address via an App Password, no custom domain needed. Generate one at
# myaccount.google.com/apppasswords (requires 2-Step Verification enabled).
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Shared secret for /cron/check-reminders. Set the same value as the
# CRON_SECRET env var in Vercel -- it auto-sends this as a Bearer token
# on cron-triggered requests, so only Vercel's own cron can call it.
CRON_SECRET=change-me
